{
  "settings": {},
  "rules": [
    {
      "patterns": [
        ".*"
      ],
      "properties": {
        "context": "default",
        "pull_to_refresh_enabled": true
      }
    },
    {
      "patterns": [
        "/new$"
      ],
      "properties": {
        "context": "modal",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": [
       "^/$", "^/feed$", "^/later$", "^/archive$", "^/subscriptions$", "^/session/new$"
      ],
      "properties": {
        "context": "default",
        "presentation": "replace"
      }
    },
    {
      "patterns": [
       "^/\\?format=html$"
      ],
      "properties": {
        "context": "default",
        "presentation": "replace_root"
      }
    },
    {
      "patterns": [
        "^/user$",
      ],
      "properties": {
        "context": "modal"
      }
    }
  ]
}

