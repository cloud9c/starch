{
  "settings": {},
  "rules": [
    {
      "patterns": [
        ".*"
      ],
      "properties": {
        "context": "default",
        "pull_to_refresh_enabled": true
      }
    },
    {
      "patterns": [
        "/new$"
      ],
      "properties": {
        "context": "modal",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": [
       "^/\\?format=html$"
      ],
      "properties": {
        "context": "default",
        "presentation": "replace_root"
      }
    },
    {
      "patterns": [
        "^/user$"
      ],
      "properties": {
        "context": "modal"
      }
    },
    {
      "patterns": [
       "/session/new"
      ],
      "properties": {
        "context": "modal",
        "presentation": "replace"
      }
    }
  ]
}
