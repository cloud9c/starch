<turbo-frame id="my_navigation">
    <%= link_to root_path do %>
      <%= image_tag "icons/star-fill.svg" %>
      <span>Inbox<span>
    <% end %>

    <%= link_to later_path do %>
      <%= image_tag "icons/clock-fill.svg" %>
      <span>Later<span>
    <% end %>

    <%= link_to feed_path do %>
      <%= image_tag "icons/newspaper-clipping-fill.svg" %>
      <span>Feed<span>
    <% end %>

    <%= link_to subscriptions_path do %>
      <%= image_tag "icons/plus-circle-fill.svg" %>
      <span>Subscriptions<span>
    <% end %>

    <%= link_to search_path do %>
      <%= image_tag "icons/binoculars-fill.svg" %>
      <span>Search<span>
    <% end %>

    <%= link_to archive_path do %>
      <%= image_tag "icons/archive-fill.svg" %>
      <span>Archive<span>
    <% end %>
</turbo-frame>
