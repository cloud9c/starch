<turbo-frame id="my_navigation">
  <% 
  navigation_items = [
    { path: root_path, icon: "icons/star-fill.svg", text: "Inbox" },
    { path: feed_path, icon: "icons/newspaper-clipping-fill.svg", text: "Feed" },
    { path: later_path, icon: "icons/clock-fill.svg", text: "Later" },
    { path: subscriptions_path, icon: "icons/plus-circle-fill.svg", text: "Subscriptions" },
    { path: search_path, icon: "icons/binoculars-fill.svg", text: "Search" },
    { path: archive_path, icon: "icons/archive-fill.svg", text: "Archive" }
  ]
  %>
  
  <% navigation_items.each_with_index do |item, index| %>
    <%= link_to item[:path], data: { controller: "shortcut", "shortcut-hotkey-value": (index + 1).to_s } do %>
      <%= image_tag item[:icon], class: "icon" %>
      <span><%= item[:text] %></span>
    <% end %>
  <% end %>
</turbo-frame>
