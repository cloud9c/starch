<% content_for(:title) { 'Sign in to Starch' } %>

<div class="page page--login align--center push--top">
  <div>
    <img src="/icon.svg" class="login__logo push_quarter--bottom" />
    <h1 class="heading align--center">
      Starch
    </h1>
  </div>

  <div class="login__form">
    <%= form_with(url: verify_session_path) do |form| %>
      <%= form.label :verification_code do %>
        <p>Enter the code sent to</p>
        <p class="login__email-address"><%= params[:email_address] %></p>
      <% end %>
      <%= form.text_field :verification_code, 
                          pattern: "[0-9]*", 
                          required: true, 
                          inputmode: "numeric",
                          maxlength: 6,
                          autocomplete: "off",
                          autofocus: true %>
      <%= form.submit "Verify email address", class: "btn btn--primary push--top" %>
      <%= invisible_captcha %>
    <% end %>
  </div>
    <%= link_to "Go back", :back, class: "btn btn--outline btn--secondary btn--icon icon--arrow-left web-only push_double--top" %>
</div>
