<% content_for(:title) { 'Sign in to Starch' } %>

<div class="page page--login push--top">
  <div class="align--center push--bottom">
    <img src="/icon.svg" class="login__logo push_quarter--botto " />
    <h1 class="heading align--center">
      Starch
    </h1>
  </div>

  <%= form_with(url: session_path, id: "login__form", class: "align--center") do |form| %>
    <%= form.label :email_address, "Enter your email address"%>
    <%= form.email_field :email_address, required: true, autofocus: true %>
    <%= form.submit "Continue", class: "btn btn--primary push--top" %>

    <%# <span class="auth-divider">Or</span> %>

    <%# form.submit "Sign in with passkey", class: "btn" %>


    <%= invisible_captcha %>
  <% end %>

</div>
