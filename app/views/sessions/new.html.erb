<div class="mx-auto md:w-2/3 w-full">
  <h1 class="text-lg font-bold mb-4">Login</h1>

  <%= form_with(url: session_path, class: "space-y-4") do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm" %>
    </div>

    <%= f.submit "Send Magic Link", class: "rounded-lg py-3 px-5 bg-blue-600 text-white" %>
  <% end %>
</div>

<% flash.each do |name, msg| %>
  <div class="<%= name == 'alert' ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %> p-4 mb-4 rounded">
    <%= msg %>
  </div>
<% end %>