<div class="sheet">
  <h1 class="sheet__header">Starch</h1>
  <div class="content">
    <% if @show_verification %>
      <%= form_with(url: verify_session_path, data: { turbo: false }, class: "login-form") do |form| %>
        <%= form.label :verification_code, "Enter verification code" %>
        <%= form.text_field :verification_code, maxlength: 6, pattern: "[0-9]*" %>
        <%= form.submit "Verify code" %>
      <% end %>
    <% else %>
      <%= form_with(url: session_path, data: { turbo: false }, class: "login-form") do |form| %>
        <%= form.label :email_address, "Enter your email" %>
        <%= form.email_field :email_address %>
        <%= form.submit "Continue" %>
        <%= invisible_captcha %>
      <% end %>
    <% end %>
  </div>
</div>
