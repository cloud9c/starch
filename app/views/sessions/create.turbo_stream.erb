<% if @flash %>
  <%= turbo_stream.replace "flash" do %>
    <%= render "shared/flash", flash: @flash %>
  <% end %>
<% end %>
<% if @flash && @flash[:show_verification] %>
  <%= turbo_stream.replace "login__content" do %>
    <%= form_with(url: verify_session_path, class: "login-form") do |form| %>
      <%= form.label :verification_code, "Enter verification code" %>
      <%= form.text_field :verification_code, pattern: "[0-9]*", required: true, inputmode: "numeric" %>
      <%= form.submit "Verify code", class: "btn" %>
      <%= invisible_captcha %>
    <% end %>
  <% end %>
<% end %>
