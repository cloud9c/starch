<turbo-frame id="checkout">
  <script src="https://js.stripe.com/v3/"></script>
  <div id="checkout-container" data-controller="checkout"
       data-checkout-target="container"
       data-checkout-stripe-key-value="<%= Rails.application.credentials.dig(Rails.env.to_sym, :stripe, :publishable_key) %>"></div>
</turbo-frame>
