<turbo-frame id="document_toolbar">
  <%= form_with model: @document_state, class: "toolbar", data: {controller: "toolbar"} do |form| %>
    <%= form.hidden_field :document_id, value: params[:document_id] %>
    <%= link_to "Back", "javascript:history.back()", class: "icon icon--arrow-left mobile-only web-only toolbar__action" %>
    <% DocumentState.statuses.keys.each do |status| %>
      <%= form.button type: :submit, 
      name: "document_state[status]",
      value: status,
      class: "toggle icon--#{status} shortcut-hotkey shortcut-hotkey__corner toolbar__action",
      onchange: "this.form.requestSubmit()",
      "aria-label": "Send to #{status.titleize}",
      data: {
        controller: "shortcut",
        "toolbar-target": "documentState",
        action: "click->toolbar#updateDocumentState",
        "shortcut-hotkey-value": status[0].downcase,
        checked: (@document_state&.status == status unless @document_state.new_record?) 
      } do %>
        <span><%= status.titleize %></span>
      <% end %>
    <% end %>
  <% end %>
</turbo-frame>
