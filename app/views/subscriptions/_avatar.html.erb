<% active = params["subscription"] == avatar.id.to_s %>

<a class="subscription-avatar" href="<%= active ? "?" : "?subscription=#{avatar.id}" %>" data-active="<%= active ? "true" : "false" %>" data-turbo-stream="true" >
  <% channel = avatar.channel %>
  <picture>
    <source srcset="<%= channel.icon %>"/>
    <%= image_tag "icons/rss.svg", alt: "#{channel.title} icon"%>
  </picture>
  <span><%= channel.title || channel.feed_url %></span>
</a>
