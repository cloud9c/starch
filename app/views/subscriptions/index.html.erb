<% content_for(:title) { "Subscriptions" } %>

<div class="sheet">
  <h1 class="sheet__header">Subscriptions</h1>
  <div class="content subscription-content">
    <%= form_with(model: Subscription, id: "add-subscription") do |f| %>
      <%= f.text_field :feed_url, 
          placeholder: "Enter link",
          required: true %>
      <%= f.button "Add to inbox",
        class: "btn btn--icon icon--inbox",
        name: "subscription[to_inbox]",
        value: "true" %>
      <%= f.button "Add",
        class: "btn btn--secondary btn--icon icon--plus",
        name: "subscription[to_inbox]",
        value: "false" %>
    <% end %>

    <div id="subscription-list">
      <%= render partial: 'subscriptions/preview', collection: @subscriptions, cached: true %>
    </div>
  </div>
</div>
