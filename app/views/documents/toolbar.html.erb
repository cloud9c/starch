<turbo-frame id="document_toolbar" target="_top">
  <%= form_with model: @document, class: "toolbar", data: {
    turbo: false,
    controller: "toolbar" } do |form| %>
    <%= form.hidden_field :id, value: params[:id] %>
    <%= toolbar_toggle(
      text: "Read Later",
      short_text: "Later",
      icon: "later",
      status: "later",
      checked_status: "inbox"
    ) unless @document.status == "trash" %>

    <% if @document.status == "trash" %>
      <%= toolbar_toggle(
        text: "Restore to Inbox",
        short_text: "Restore",
        icon: "restore",
        status: "inbox") %>
    <% else %>
      <%= toolbar_toggle(
        text: "Trash",
        icon: "trash",
        status: "trash") %>
    <% end %>

    <% unless @document.status == "trash" %>
      <%= toolbar_move %>
    <% end %>
  <% end %>
</turbo-frame>
