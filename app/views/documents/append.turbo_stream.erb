<%= turbo_stream.append  "inbox__unread-section" do %>
  <%= render partial: 'documents/preview', collection: @unread_documents, cached: true %>
<% end %>

<%= turbo_stream.append  "inbox__read-section" do %>
  <%= render partial: 'documents/preview', collection: @read_documents, cached: true %>
<% end %>

<%= turbo_stream.append "documents-section" do %>
  <%= render partial: 'documents/preview', collection: @documents, cached: true %>
<% end %>
