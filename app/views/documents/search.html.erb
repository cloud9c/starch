<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div id="document-inbox" class="sheet" data-controller="documents--list" 
     data-documents--list-query-value="<%= "q=#{params[:query]}" %>">

   <h1 class="content-header">Search</h1>
  <div class="document-preview-section" id="documents-section">
    <% if @documents.any? %>
      <%= render partial: 'documents/preview', collection: @documents, cached: true %>
    <% else %>
      <div class="document-inbox-nothing-new">
        <span>No results.</span>
      </div>
    <% end %>
</div>