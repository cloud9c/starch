<% content_for(:title) { "Search" } %>

<div id="document-inbox" class="sheet" data-controller="documents__list" 
     data-documents__list-query-value="<%= "q=#{params[:query]}" %>">
  <h1 class="sheet__header">Search</h1>
  <div class="document-preview-section content" id="documents-section">
    <% if @documents.any? %>
      <%= render partial: 'documents/preview', collection: @documents, cached: ->(document) { [document, document.view_extracted] }  %>
    <% else %>
      <div class="document-inbox-nothing-new">
        <span>No results.</span>
      </div>
    <% end %>
</div>
