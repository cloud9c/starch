<div id="document-list" data-infinite-scroll-target="items">
  <% if @documents.present? %>
    <% @documents.each do |document| %>
      <%= turbo_frame_tag "preview_#{document.id}", src: preview_document_path(document) do %>
        <div>Loading...</div>
      <% end %>
    <% end %>
  <% else %>
    <p>No documents found.</p>
  <% end %>
</div>