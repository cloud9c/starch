<% content_for(:title) { 'Feed' } %>

<div class="document-list page page--tab" data-controller="pagination navbar-user" 
                                          data-pagination-query-value="<%= "subscription=#{params[:subscription]}" %>"
                                          data-bridge-user-hue="<%= navbar_user_hue %>" data-bridge-user-title="<%= navbar_user_title %>">
  <h1 class="heading web-only">Feed</h1>

  <%= render "subscriptions/avatar_list", subscriptions: @subscriptions %>

  <div class="document-preview-section" id="documents-section">
    <% if @documents.any? %>
      <%= render partial: 'documents/preview', collection: @documents %>
    <% else %>
      <div class="document-list__nothing-new">
        <span>No results.</span>
      </div>
    <% end %>
  </div>
</div>
