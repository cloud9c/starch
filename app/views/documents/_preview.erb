<%= turbo_frame_tag "preview_#{document.id}" do %>
  <%= link_to document_path(document, view_extracted: document.view_extracted?),
      data: { turbo_frame: "_top" },
      id: dom_id(document),
      class: "document-item" do %>
    <header>
      <div class="channel-container">
        <picture>
          <source srcset="<%= @document.channel.icon %>"/>
          <%= image_tag "icons/feed-icon.svg", width: 24, alt: "#{@document.channel.title} icon" %>
        </picture>
        <%= document.channel.title %>
      </div>

      <% if document.published_at %>
        <p><%= document.published_at.strftime("%b %d, %Y") %></p>
      <% end %>
    </header>
    <main>
      <div>
        <h1><%= document.title %></h1>
        <p><%= document.description %></p>
        <p><%= document.author %> · X min read</p>
      </div>
      <div>
        <% if document.thumbnail_url %>
          <img src="<%= document.thumbnail_url %>" 
               width="160"
             height="120"
             alt="Thumbnail"/>
        <% end %>
      </div>
    </main>
  <% end %>
<% end %>