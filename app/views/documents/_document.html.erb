<%= link_to document_path(document, t: session["document_#{document.id}_updated_at"]),
    data: { turbo_frame: "_top" },
    id: dom_id(document),
    class: "document-item" do %>
  <header>
    <div>
      <% if document.entry %>
        <img src="<%= document.channel_icon %>" 
             width="24" 
             alt="<%= document.channel_title %> icon"/>
      <% end %>
      <span><%= document.channel_title %></span>
    </div>
    <% if document.published_at %>
      <p><%= document.published_at.strftime("%b %d, %Y") %></p>
    <% end %>
  </header>
  <main>
    <div>
      <h1><%= document.get_attribute(:title) %></h1>
      <p><%= document.get_attribute(:description) %></p>
      <p><%= document.get_attribute(:author) %> · X min read</p>
    </div>
    <div>
      <% if document.get_attribute(:thumbnail_url) %>
        <img src="<%= document.get_attribute(:thumbnail_url) %>" 
             width="160"
           height="120"
           alt="Thumbnail"/>
      <% end %>
    </div>
  </main>
<% end %>