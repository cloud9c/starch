<div id="<%= dom_id(@document) %>">
  <div>
    <% if @document.entry %>
      <img src="<%= @document.channel_icon %>" 
           width="24" 
           alt="<%= @document.channel_title %> icon"/>
    <% end %>
    <span><%= @document.title %></span>
  </div>
  <a href="<%= @document.url %>"><%= @document.url %></a>
  <p>description: <%= @document.description %></p>
  <p>content: <%= @document.content %></p>
</div>