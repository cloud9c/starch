
<% content_for(:title) { "Subscriptions" } %>

<div class="page">
  <h1 class="page__header align--center">
    <% case response.code.to_i %>
    <% when 400 %>
      Bad Request.
    <% when 404 %>
      Not Found.
    <% when 406 %>
      Not Acceptable.
    <% when 422 %>
      Unprocessable Entity.
    <% when 500 %>
      Internal Server Error.
    <% else %>
      An unexpected error occurred.
    <% end %>
  </h1>
  <p class="push--bottom">That's an error.</p>
  <%= link_to "Go to inbox", inbox_path, class: "btn" %>
</div>
