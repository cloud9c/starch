<h1>Starch</h1>
<%= render 'shared/searchbar' %>

<% if @results.present? %>
  <div>
    <% @results["hits"].each do |hit| %>
      <% doc = hit["document"] %>
      
      <a href="<%= doc["link"] %>">
        <h4><%= doc["title"] %></h4>
      </a>
      <p><%= doc["description"] %></p>
    <% end %>
  </div>
<% elsif @query.present? %>
  <p>No results found for "<%= @query %>"</p>
<% end %>