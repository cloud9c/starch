<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Starch" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="oklch(17.5% 280 0.02)" media="(prefers-color-scheme: dark)">
    <meta name="apple-itunes-app" content="app-id=6743105949">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylepage files in app/assets/stylepages %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body data-controller="<%="shortcut detect-scroll" if authenticated? %>" class="<%= "native" if hotwire_native_app?%>">
    <%= render "shared/flash" %>
    <% if authenticated? %>
      <%= content_for?(:top_content) ? yield(:top_content) : render('shared/navbar') %>
    <% end %>
    <main class="main">
      <%= yield %>
    </main>
    <% if authenticated? %>
      <%= content_for?(:bottom_content) ? yield(:bottom_content) : render('shared/bottom_navbar') %>
    <% end %>
  </body>
</html>
