<div id="tabbar" class="web-only">
  <% 
  navigation_items = [
    { path: inbox_path, icon: "inbox", text: "Inbox" },
    { path: feed_path, icon: "feed", text: "Feed" },
    { path: later_path, icon: "later", text: "Later" },
  ]
  %>

  <div id="navigation">
    <% navigation_items.each_with_index do |item, index| %>
      <%= link_to item[:path],
          data: { current: current_page?(item[:path]) ? 'true' : 'false' },
          class: "icon icon--#{item[:icon]} icon--unselected navigation-item text--unselected" do %>
        <span><%= item[:text] %></span>
      <% end %>
    <% end %>
  </div>
</div>
