<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Starch — one place to read them all" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="oklch(17.5% 0 0)" media="(prefers-color-scheme: dark)">
    <meta name="apple-itunes-app" content="app-id=6743105949">

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylepage files in app/assets/stylepages %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body>
    <main class="main">
      <%= yield %>
    </main>
  </body>
</html>
